# ── Required ───────────────────────────────────────────────────────────────────

# Your Discord bot token
# discord.com/developers/applications → your app → Bot → Token
DISCORD_BOT_TOKEN=

# Your logged.tg session cookie
# Firefox mobile: go to logged.tg while logged in, type in URL bar:
#   javascript:alert(document.cookie)
# Copy the value shown in the popup
LOGGED_TG_SESSION_COOKIE=

# ── Optional ───────────────────────────────────────────────────────────────────

# Restrict !stats to one Discord channel (leave blank = all channels allowed)
# Right-click a channel → Copy Channel ID
STATS_CHANNEL_ID=
